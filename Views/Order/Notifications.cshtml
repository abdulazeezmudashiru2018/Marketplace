@model IEnumerable<MarketPlace.Models.Order>
@{
    ViewData["Title"] = "Notifications";
}
<div class="container my-4">
    <h2 class="mb-1 fw-bold">🔔 Order Notifications</h2>
    <p class="text-muted">Everyone who placed an order. Click a name to see their order details.</p>
    @if (!Model.Any())
    {
        <div class="alert alert-info">No orders yet.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var o in Model)
            {
                <a asp-controller="Order" asp-action="OrderDetails" asp-route-id="@o.Id"
                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fw-semibold">@o.FullName</div>
                        <div class="text-muted small">
                            @o.Items.Count item(s) • @o.CreatedAt.ToString("dd MMM yyyy, h:mm tt")
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="fw-semibold">₦@o.Total.ToString("N2")</div>
                        @if (o.IsPaid)
                        {
                            <span class="badge bg-success">Paid</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                    </div>
                </a>
            }
        </div>
    }
</div>
