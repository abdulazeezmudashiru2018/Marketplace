
@model List<MarketPlace.Models.Product>

@{
    ViewData["Title"] = "AddGoods Page";
}


<!-- Invoice Area -->

<div class="AddGoods-container">

    <!-- Header -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>GOODS MANAGEMENT</h2>

        <h4 id="currentDateTime"></h4>
               
    </div>      
          

    <div class="company-header">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div class="company-logo">

                🥤

            </div>


            <div class="company-title">

                <h1>PRESTIGE</h1>

                <h2>SOFT DRINK STORE</h2>

                <p class="company-description">

                    Dealer in all kinds of soft drinks such as

                    Coke, Fearless, Malt, Viju Milk,

                    Yogurt etc.

                    Both Wholesale and Retail.

                </p>

            </div>

            <button class="btn btn-primary"
                    onclick="resetProductForm()"
                    data-bs-toggle="modal"
                    data-bs-target="#uploadModal">

                <i class="bi bi-plus-circle"></i>

                Add Items

            </button>

        </div>
                

        <div class="text-center">

            <div class="company-contact">

                <p>

                    <i class="bi bi-geo-alt-fill"></i>
                                                  

                    Formal Dave Mercy Clinic,

                    Idiagbo,

                    Jebba,

                    Kwara State.
                                 

                </p>
                                     

                <p>

                    <i class="bi bi-telephone-fill"></i>

                    08000000000

                </p>

            </div>

        </div>

    </div>


    <div class="row mb-4">

        <div class="col-md-6">

            <div class="input-group">

                <span class="input-group-text">

                    🔍

                </span>

                <input type="text"
                       id="searchProduct"
                       class="form-control"
                       placeholder="Search Product..."
                       onkeyup="searchProduct()">

            </div>

        </div>

    </div>


    <div class="container mt-4">

        <div class="row" id="goodsContainer">

            @foreach (var product in Model)
            {
                <div class="col-md-2 mb-3" data-id="@product.Id">

                    <div class="card shadow-sm">

                        <img src="@product.ProductImage"
                             class="card-img-top"
                             style="height:120px;object-fit:cover;" />

                        <div class="card-body text-center p-1">

                            <div class="product-name"
                                 style="
                                font-size:10px;
                                font-weight:bold;
                                line-height:1.1;
                                margin:0;">
                                @product.ProductName
                            </div>

                            <div class="product-price"
                                 style="
                                font-size:10px;
                                font-weight:bold;
                                margin:0;">
                                ₦@product.ProductPrice
                            </div>

                            <div class="d-flex justify-content-center gap-1 mt-1">

                                <button class="btn btn-primary btn-sm"
                                        onclick="editProduct(this)">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                                <form asp-controller="AddGoods"
                                      asp-action="DeleteProduct"
                                      method="post"
                                      style="display:inline;">

                                    <input type="hidden"
                                           name="id"
                                           value="@product.Id" />

                                    <button type="submit"
                                            class="btn btn-danger btn-sm"
                                            onclick="return confirm('Delete this item?');">

                                        <i class="bi bi-trash"></i>

                                    </button>

                                </form>
                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>
</div>


<div class="modal fade"
     id="uploadModal"
     tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">

                <h5>Add New Item</h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body text-center">

                <button class="btn btn-success m-2"
                        onclick="openGallery()">

                    <i class="bi bi-images"></i>

                    Gallery

                </button>

                <button class="btn btn-info m-2"
                        onclick="openCamera()">

                    <i class="bi bi-camera"></i>

                    Camera

                </button>

                <hr>

                <input type="file"
                       id="imageInput"
                       accept="image/*"
                       hidden>

                <img id="previewImage"
                     width="12"
                     class="mt-3"
                     style="display:none;">

                <input type="text"
                       id="productName"
                       name="ProductName"
                       class="form-control mt-3"
                       placeholder="Product Name">

                <input type="number"
                       id="productPrice"
                       name="ProductPrice"
                       class="form-control mt-3"
                       placeholder="Product Price">
            </div>

            <div class="modal-footer">

                <form asp-controller="AddGoods"
                      asp-action="SaveProduct"
                      method="post">

                    <input type="hidden"
                           name="ProductImage"
                           id="hiddenImage" />

                    <input type="hidden"
                           name="ProductName"
                           id="hiddenProductName" />

                    <input type="hidden"
                           name="ProductPrice"
                           id="hiddenProductPrice" />

                    <button type="submit"
                            class="btn btn-primary"
                            onclick="prepareProductData()">
                        Apply
                    </button>

                </form>

            </div>

        </div>

    </div>
       

</div>


<div class="modal fade"
     id="editModal"
     tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">

                <h5>Edit Product</h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>
            <form asp-controller="AddGoods"
                  asp-action="EditProduct"
                  method="post">

                <input type="hidden"
                       name="Id"
                       id="editProductId" />

                <div class="modal-body">

                    <input type="text"
                           name="ProductName"
                           id="editProductName"
                           class="form-control mb-3"
                           placeholder="Product Name">

                    <input type="number"
                           name="ProductPrice"
                           id="editProductPrice"
                           class="form-control"
                           placeholder="Product Price">

                </div>

                <div class="modal-footer">

                    <button type="submit"
                            class="btn btn-success">

                        Apply

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>


<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<script>



        let currentEditCard = null;



          function updateClock(){

             document.getElementById("currentDateTime").innerHTML =
              new Date().toLocaleString();

        }

            setInterval(updateClock,1000);

               updateClock();


                   function resetProductForm()
    {
        // Clear image preview
        let img = document.getElementById("previewImage");

        if(img)
        {
            img.src = "";
            img.style.display = "none";
        }

        // Clear selected file
        document.getElementById("imageInput").value = "";

        // Clear product name
        document.getElementById("productName").value = "";

        // Clear product price
        document.getElementById("productPrice").value = "";
    }



        function openGallery()
    {
        document.getElementById("previewImage")
            .style.display = "none";

        document.getElementById("previewImage")
            .removeAttribute("src");

        document.getElementById("productName").value = "";

        document.getElementById("productPrice").value = "";

        let input =
            document.getElementById("imageInput");

        input.removeAttribute("capture");

        input.click();
    }


        function openCamera()
    {
        document.getElementById("previewImage")
            .style.display = "none";

        document.getElementById("previewImage")
            .removeAttribute("src");

        document.getElementById("productName").value = "";

        document.getElementById("productPrice").value = "";

        let input =
            document.getElementById("imageInput");

        input.setAttribute(
            "capture",
            "environment"
        );

        input.click();
    }


        document.getElementById("imageInput")
    .addEventListener("change", function(e)
    {
        let file = e.target.files[0];

        if(file)
        {
            let reader = new FileReader();

            reader.onload = function(event)
            {
                let img =
                    document.getElementById("previewImage");

                img.src = event.target.result;
                img.style.display = "block";
            };

            reader.readAsDataURL(file);
        }
    });

       
        function saveProduct()
    {
        let image =
            document.getElementById("previewImage").src;

        let name =
            document.getElementById("productName").value;

        let price =
            document.getElementById("productPrice").value;

       
        if(image === "" || !name || !price)
        {
            alert(
                "Please select image, name and price"
            );

            return;
        }

        let html = `

        <div class="col-md-2 mb-3">

            <div class="card shadow-sm">

                <img src="${image}"
                     class="card-img-top"
                     style="
                     height:80px;
                     object-fit:cover;">

                <div class="card-body text-center p-1">

                    <div class="product-name"
                         style="
                         font-size:10px;
                         font-weight:bold;
                         line-height:1.1;
                         margin:0;">
                        ${name}
                    </div>

                        <div class="product-price"
                         style="
                        font-size:10px;
                         font-weight:bold;
                          margin:0;">
                          ₦${price}
                           </div>

                    <div class="d-flex justify-content-center gap-1 mt-1">

        <button class="btn btn-primary btn-sm"
                onclick="editProduct(this)">
            <i class="bi bi-pencil-square"></i>
        </button>

        <button class="btn btn-danger btn-sm"
                onclick="deleteProduct(this)">
            <i class="bi bi-trash"></i>
        </button>

    </div>

                </div>

            </div>

        </div>
        `;

        document.getElementById(
            "goodsContainer"
        ).insertAdjacentHTML(
            "beforeend",
            html
        );



            resetProductForm();

             // Force refresh of controls
              document.getElementById("productName").value = "";
             document.getElementById("productPrice").value = "";
             document.getElementById("imageInput").value = "";

       let img =
                document.getElementById("previewImage");

                img.src = "";
                    img.style.display = "none";


             document.getElementById("productName").focus();
}

    function deleteProduct(button)
    {
        button.closest(".col-md-2").remove();
    }


        function searchProduct()
    {
        let input =
            document.getElementById(
                "searchProduct"
            ).value.toLowerCase();

        let cards =
            document.querySelectorAll(
                "#goodsContainer .col-md-2"
            );

        cards.forEach(card =>
        {
            let productName =
                card.querySelector(
                    ".product-name"
                ).innerText.toLowerCase();

            if(productName.includes(input))
            {
                card.style.display = "";
            }
            else
            {
                card.style.display = "none";
            }
        });
    }

                function editProduct(button)
        {
            currentEditCard =
                button.closest(".col-md-2");

            let id =
                currentEditCard.getAttribute("data-id");

            let name =
                currentEditCard.querySelector(".product-name")
                .innerText.trim();

            let price =
                currentEditCard.querySelector(".product-price")
                .innerText.replace("₦","").trim();

            document.getElementById("editProductId").value = id;

            document.getElementById(
                "editProductName"
            ).value = name;

            document.getElementById(
                "editProductPrice"
            ).value = price;

            let modal =
                new bootstrap.Modal(
                    document.getElementById("editModal")
                );

            modal.show();
        }


        function saveEditedProduct()
    {
        let newName =
            document.getElementById(
                "editProductName"
            ).value;

        let newPrice =
            document.getElementById(
                "editProductPrice"
            ).value;

        currentEditCard.querySelector(
            ".product-name"
        ).innerText = newName;

        currentEditCard.querySelector(
            ".product-price"
        ).innerText = "₦" + newPrice;

        bootstrap.Modal.getInstance(
            document.getElementById(
                "editModal"
            )
        ).hide();
    }


        function prepareProductData()
    {
        document.getElementById("hiddenImage").value =
            document.getElementById("previewImage").src;

        document.getElementById("hiddenProductName").value =
            document.getElementById("productName").value;

        document.getElementById("hiddenProductPrice").value =
            document.getElementById("productPrice").value;
    }

</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>